<div class="search js-search {{ class }}">
    <div class="search__top search-top">
        <input type="text" class="search-top__input js-search__input" placeholder="Поиск по каталогу">

        <button type="button" class="search-top__close js-search__close">
            <svg width="9" height="9">
                <use href="img/svg/icons.svg#close-9-9"></use>
            </svg>
        </button>

        <button type="button" class="search-top__button">
            <svg class="search-top__icon">
                <use href="img/svg/icons.svg#search-18-18"></use>
            </svg>
        </button>
    </div>

    {% include '@components/ui/close.twig' with {
        class: 'search__close js-search__close'
    } %}

    <div class="search__dropdown search-dropdown js-search__dropdown">
        <div class="search-dropdown__scroll">
            <div class="search-dropdown__col">
                <div class="search-dropdown__title">Категории</div>

                <div class="search__categories search-categories">
                    {% for item in 1..3 %}
                        <a href="" class="search__category search-category">
                            <b>Сп</b>ортивные товары
                        </a>
                    {% endfor %}
                </div>
            </div>

            <div class="search-dropdown__col">
                <div class="search-dropdown__title">Товары</div>

                <div class="search__products search-products">
                    {% for item in 1..5 %}
                        <a href="" class="search__product search-product">
                            <img src="https://premier-demo.ru/upload/resize_cache/iblock/a87/80_80_1/pgie84269c3w1szjx62uijdiaw0sqoox.jpg"
                                 alt="" class="search-product__image">

                            <span class="search-product__info">
                                <span class="search-product__title">Спальный мешок-одеяло с капюшоном Snug</span>

                               {% include '@components/@shop/price.twig' with {
                                    class: 'search-product__price',
                                    size: 'sm',
                                    now: '1 300 ₽/шт',
                                    old: '1 600 ₽/шт'
                               } %}
                            </span>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="search-dropdown__footer">
            <a href="" class="button button-transparent-bg">
                Все результаты
            </a>
        </div>
    </div>
</div>