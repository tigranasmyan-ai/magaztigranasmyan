<button type="button" class="{{ theme_switch_classes }} theme-switch js-theme-toggle">
    <span class="theme-switch__icon">
        <svg width="16" height="16">
            <use xlink:href="img/svg/icons.svg#dark-sm"></use>
        </svg>

        <svg width="16" height="16">
             <use xlink:href="img/svg/icons.svg#light-sm"></use>
        </svg>
    </span>

    {% if text %}
        <span class="theme-switch__text" data-dark-theme-text="Темная тема" data-light-theme-text="Светлая тема"></span>
    {% endif %}
</button>