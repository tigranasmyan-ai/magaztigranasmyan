{% set actions = [
    { href: '', icon: 'phone-14-18', text: 'Звонок', width: 18, height: 18, counter: false, class: 'disabled-desktop' },
    { href: '', icon: 'search-18-18', text: 'Поиск', width: 18, height: 18, counter: false, class: 'disabled-desktop' },
    { href: '', icon: 'log-in', text: 'Войти', width: 18, height: 18, counter: false },

    { href: 'compare.html', icon: 'compare', text: 'Сравнение', width: 20, height: 20, counter: true, class: 'disabled-mobile' },
    { href: 'favorites.html', icon: 'favorite', text: 'Избранное', width: 20, height: 20, counter: true, class: 'disabled-mobile' },
    { href: 'cart.html', icon: 'cart-20-18', text: 'Корзина', width: 20, height: 20, counter: true }
] %}

<header class="site-header {{ page_settings.compact ? 'compact' : '' }} js-header">
    <div class="site-header__container container">
        <div class="site-header__top">
            {# Город #}
            <div class="site-header__location site-header-location">
                <svg class="site-header-location__icon">
                    <use xlink:href="img/svg/icons.svg#region-sm"></use>
                </svg>

                <span class="site-header-location__value">
                    Челябинск
                </span>
            </div>

            {# Меню #}
            {% include '@components/menu/menu-mega.twig' with {
                class: 'site-header__menu',
            } %}

            {# Контакты #}
            <div class="site-header__callback site-header-callback">
                {% include '@components/contacts-widget.twig' %}

                <a data-bs-toggle="modal" data-bs-target="#CallbackModal" class="site-header-callback__value">Заказать
                    звонок</a>
            </div>

            {% include '@components/theme-switch.twig' with { theme_switch_classes: 'site-header__switcher' } %}
        </div>
    </div>

    <div class="site-header__main">
        <div class="container">
            <div class="site-header__left">
                <button class="site-header__burger" type="button" data-bs-toggle="offcanvas" data-bs-target="#LeftMenu" aria-controls="LeftMenu">
                    <svg width="20" height="14">
                        <use href="img/svg/icons.svg#burger-16-12"></use>
                    </svg>
                </button>

                <a href="/home.html" class="site-header__logo logo">
                    <svg width="168" height="32" viewBox="0 0 168 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                                d="M0 16C0 7.16344 7.16344 0 16 0H32V16C32 24.8366 24.8366 32 16 32L8 32V16C8 11.5817 11.5817 8 16 8H24V16C24 20.4183 20.4183 24 16 24V20C18.2091 20 20 18.2091 20 16V12H16C13.7909 12 12 13.7909 12 16V28H16C22.6274 28 28 22.6274 28 16V4H16C9.37258 4 4 9.37258 4 16L4 24H0V16Z"/>
                        <path fill-rule="evenodd" clip-rule="evenodd"
                              d="M71.4894 8.60986C73.5494 8.60986 75.3094 9.37986 76.7694 10.9199C78.2294 12.4399 78.9594 14.2999 78.9594 16.4999C78.9594 18.7199 78.2294 20.5899 76.7694 22.1099C75.3094 23.6299 73.5494 24.3899 71.4894 24.3899C69.2094 24.3899 67.4594 23.5499 66.2394 21.8699V29.9999H62.9994V8.99986H66.2394V11.1599C67.4594 9.45986 69.2094 8.60986 71.4894 8.60986ZM67.5894 19.9499C68.4894 20.8499 69.6194 21.2999 70.9794 21.2999C72.3394 21.2999 73.4694 20.8499 74.3694 19.9499C75.2694 19.0299 75.7194 17.8799 75.7194 16.4999C75.7194 15.1199 75.2694 13.9799 74.3694 13.0799C73.4694 12.1599 72.3394 11.6999 70.9794 11.6999C69.6194 11.6999 68.4894 12.1599 67.5894 13.0799C66.6894 13.9799 66.2394 15.1199 66.2394 16.4999C66.2394 17.8799 66.6894 19.0299 67.5894 19.9499ZM86.0959 20.5199C85.2359 19.8999 84.6859 19.0199 84.4459 17.8799H96.3859C96.4659 17.3199 96.5059 16.8699 96.5059 16.5299C96.5059 14.3299 95.7959 12.4599 94.3759 10.9199C92.9759 9.37986 91.1759 8.60986 88.9759 8.60986C86.6559 8.60986 84.7559 9.36986 83.2759 10.8899C81.7959 12.3899 81.0559 14.2599 81.0559 16.4999C81.0559 18.7799 81.8059 20.6699 83.3059 22.1699C84.8059 23.6499 86.7759 24.3899 89.2159 24.3899C92.1159 24.3899 94.3059 23.2999 95.7859 21.1199L93.1159 19.5599C92.2559 20.7999 90.9659 21.4199 89.2459 21.4199C88.0059 21.4199 86.9559 21.1199 86.0959 20.5199ZM93.2359 15.2399H84.4159C84.6359 14.0999 85.1459 13.1999 85.9459 12.5399C86.7459 11.8799 87.7459 11.5499 88.9459 11.5499C90.0059 11.5499 90.9259 11.8599 91.7059 12.4799C92.5059 13.0999 93.0159 14.0199 93.2359 15.2399ZM135.422 17.8799C135.662 19.0199 136.212 19.8999 137.072 20.5199C137.932 21.1199 138.982 21.4199 140.222 21.4199C141.942 21.4199 143.232 20.7999 144.092 19.5599L146.762 21.1199C145.282 23.2999 143.092 24.3899 140.192 24.3899C137.752 24.3899 135.782 23.6499 134.282 22.1699C132.782 20.6699 132.032 18.7799 132.032 16.4999C132.032 14.2599 132.772 12.3899 134.252 10.8899C135.732 9.36986 137.632 8.60986 139.952 8.60986C142.152 8.60986 143.952 9.37986 145.352 10.9199C146.772 12.4599 147.482 14.3299 147.482 16.5299C147.482 16.8699 147.442 17.3199 147.362 17.8799H135.422ZM135.392 15.2399H144.212C143.992 14.0199 143.482 13.0999 142.682 12.4799C141.902 11.8599 140.982 11.5499 139.922 11.5499C138.722 11.5499 137.722 11.8799 136.922 12.5399C136.122 13.1999 135.612 14.0999 135.392 15.2399ZM158.543 8.60986C160.603 8.60986 162.363 9.37986 163.823 10.9199C165.283 12.4399 166.013 14.2999 166.013 16.4999C166.013 18.7199 165.283 20.5899 163.823 22.1099C162.363 23.6299 160.603 24.3899 158.543 24.3899C156.263 24.3899 154.513 23.5499 153.293 21.8699V29.9999H150.053V8.99986H153.293V11.1599C154.513 9.45986 156.263 8.60986 158.543 8.60986ZM154.643 19.9499C155.543 20.8499 156.673 21.2999 158.033 21.2999C159.393 21.2999 160.523 20.8499 161.423 19.9499C162.323 19.0299 162.773 17.8799 162.773 16.4999C162.773 15.1199 162.323 13.9799 161.423 13.0799C160.523 12.1599 159.393 11.6999 158.033 11.6999C156.673 11.6999 155.543 12.1599 154.643 13.0799C153.743 13.9799 153.293 15.1199 153.293 16.4999C153.293 17.8799 153.743 19.0299 154.643 19.9499ZM128.522 15.48C127.502 14.56 126.192 14.1 124.592 14.1H121.292V9H118.052V24H124.592C126.192 24 127.502 23.54 128.522 22.62C129.542 21.7 130.052 20.51 130.052 19.05C130.052 17.57 129.542 16.38 128.522 15.48ZM126.212 20.52C125.792 20.9 125.262 21.09 124.622 21.09H121.292V17.01H124.622C125.262 17.01 125.792 17.2 126.212 17.58C126.652 17.94 126.872 18.43 126.872 19.05C126.872 19.65 126.652 20.14 126.212 20.52ZM114.307 9V24H111.157V14.13L106.837 21H106.447L102.157 14.16V24H99.0071V9H102.307L106.657 15.93L111.007 9H114.307ZM59.3494 24V9H45.9994V24H49.2394V12.06H56.1094V24H59.3494Z"/>
                    </svg>
                </a>
            </div>

            <button type="button" class="site-header-catalog__btn is-fixed button button-default button-lg js-fast-catalog__toggle">
                <svg width="14" height="14" class="site-header-catalog__icon">
                    <use href="img/svg/icons.svg#burger"></use>
                </svg>

                <svg width="14" height="14" class="site-header-catalog__icon">
                    <use href="img/svg/icons.svg#close"></use>
                </svg>

                <span>Каталог</span>
            </button>

            {% include '@components/search.twig' with {
                class: 'site-header__search',
            } %}

            <div class="site-header__actions menu-actions is-grid">
                <div class="dropdown">
                    <button type="button" data-bs-toggle="dropdown" aria-expanded="false"
                            class="menu-actions-item menu-actions__item is-grid">
                        <span class="menu-actions-item__link">
                            <span class="menu-actions-item__top">
                                <svg class="menu-actions-item__icon" width="20" height="20">
                                     <use xlink:href="img/svg/icons.svg#log-in"></use>
                                </svg>
                            </span>

                            <span class="menu-actions-item__text">Тигран</span>
                        </span>
                    </button>

                    <ul class="dropdown-menu">
                        {% for item in [
                            {text: 'Мой кабинет', href: 'account.html'},
                            {text: 'Личные данные', href: 'account-data.html'},
                            {text: 'Заказы'},
                            {text: 'Профили заказов', href: 'account-profiles.html'},
                            {text: 'Избранные товары', href: 'favorites.html'},
                            {text: 'Помощь', href: 'help.html'},
                            {text: 'Выйти'},
                        ] %}
                            <li><a class="dropdown-item" href="{{ item.href }}">{{ item.text }}</a></li>
                        {% endfor %}
                    </ul>
                </div>

                {% for action in actions %}
                    <div class="menu-actions-item menu-actions__item is-grid js-header-action {{ action.class }} {{ action.icon == 'search-action' ? 'js-search-mobile-opener' : '' }}">
                        <a href="{{ action.href }}" class="menu-actions-item__link"
                           {% if action.icon == 'log-out' %}data-bs-toggle="modal"
                           data-bs-target="#LoginModal"{% endif %}
                                {% if action.icon == 'phone-action' %}data-bs-toggle="modal" data-bs-target="#CallbackModal"{% endif %}>
                            <span class="menu-actions-item__top">
                                <svg class="menu-actions-item__icon" width="{{ action.width }}"
                                     height="{{ action.height }}">
                                    <use xlink:href="img/svg/icons.svg#{{ action.icon }}"></use>
                                </svg>

                                {% if action.counter %}
                                    <span class="menu-actions-item__counter">1</span>
                                {% endif %}
                            </span>

                            <span class="menu-actions-item__text">{{ action.text }}</span>
                        </a>

                        {% if action.counter %}
                            <div class="site-header-popup js-header-action-dropdown">
                                <div class="site-header-popup__scroll">
                                    {% for item in 1..10 %}
                                        {% include 'item/product/product-item-short.twig' %}
                                    {% endfor %}
                                </div>

                                <div class="site-header-popup__bottom">
                                    {% if action.href == 'cart.html' %}
                                        <div class="site-header-popup__total">
                                            <span class="title title-h4">
                                                Итого
                                            </span>

                                            <div class="site-header-popup__shipping">
                                                {% include '@components/@shop/price.twig' with {
                                                    size: 'lg',
                                                    now: '600 ₽',
                                                    old: '300 ₽'
                                                } %}

                                                {% include '@components/@shop/cashback.twig' %}
                                            </div>
                                        </div>
                                    {% endif %}

                                    <a href="" class="button button-default button-lg site-header-popup__button">
                                        Перейти в корзину
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="site-header__container container">
        <div class="site-header__bottom">
            <button type="button"
                    class="site-header-catalog__btn button button-default button-xl js-fast-catalog__toggle">
                <svg width="14" height="14" class="site-header-catalog-btn__icon">
                    <use href="img/svg/icons.svg#burger"></use>
                </svg>

                <svg width="14" height="14" class="site-header-catalog-btn__icon">
                    <use href="img/svg/icons.svg#close"></use>
                </svg>

                <span>Каталог</span>
            </button>

            <div class="site-header__categories site-header-categories swiper js-header-catalog-card-slider">
                <div class="swiper-wrapper">
                    <div class="swiper-slide">
                        <a href="" class="site-header-categories__main">Смартфоны</a>
                    </div>

                    {% for item in 1..5 %}
                        <div class="swiper-slide">
                            <a href="catalog.html" class="site-header-categories__item">
                                <svg class="site-header-categories__icon" xmlns="http://www.w3.org/2000/svg" height="16px" width="16px" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M5.36003 0.319999C5.62512 -0.0334628 6.12656 -0.105097 6.48003 0.159999L6.482 0.161483L6.48471 0.163531L6.49229 0.169313L6.51582 0.187551C6.53508 0.202642 6.5614 0.223599 6.59376 0.250178C6.6584 0.303278 6.74758 0.379164 6.85311 0.475901C7.06321 0.668498 7.34324 0.948397 7.62472 1.30024C7.72359 1.42383 7.82491 1.55914 7.92459 1.70531C8.05094 1.51056 8.1964 1.32939 8.3629 1.16288C9.22919 0.296594 10.4925 -1.90371e-06 12 -1.90371e-06C12.4418 -1.90371e-06 12.8 0.35817 12.8 0.799998C12.8 2.22326 12.5356 3.42891 11.777 4.28824C14.2266 5.07238 16 7.36801 16 10.0779V10.4172C16 14.5451 11.631 17.1762 8.00003 15.3073C4.36901 17.1762 3.05176e-05 14.5451 3.05176e-05 10.4172V10.0779C3.05176e-05 6.72115 2.72117 4 6.07788 4H7.17981C7.09625 3.37368 6.76395 2.78553 6.37533 2.29976C6.15681 2.0266 5.93684 1.8065 5.77195 1.65535C5.68998 1.58021 5.6229 1.52328 5.57817 1.48654C5.55584 1.4682 5.53919 1.45497 5.52916 1.44712L5.51923 1.43941C5.1661 1.17424 5.09502 0.673336 5.36003 0.319999ZM8.8426 3.95741C9.6738 3.86498 10.1834 3.62805 10.5058 3.30574C10.8281 2.98343 11.065 2.47379 11.1574 1.64258C10.3262 1.73502 9.81658 1.97194 9.49427 2.29426C9.17196 2.61657 8.93503 3.12621 8.8426 3.95741ZM1.60003 10.4172C1.60003 13.3875 4.79166 15.2644 7.38746 13.8206C7.76836 13.6088 8.23169 13.6088 8.6126 13.8206C11.2084 15.2644 14.4 13.3875 14.4 10.4172V10.0779C14.4 7.6048 12.3952 5.6 9.92216 5.6H6.07788C3.60483 5.6 1.60003 7.6048 1.60003 10.0779V10.4172Z" fill="currentColor"/>
                                </svg>

                                <span class="site-header-categories__text">Здоровое питание</span>
                            </a>
                        </div>
                    {% endfor %}
                </div>

                <div class="swiper-button-prev">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1L6 6L1 11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>

                <div class="swiper-button-next">
                    <svg width="7" height="12" viewBox="0 0 7 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1L6 6L1 11" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>
            </div>
        </div>

        <div class="site-header__catalog site-header-catalog js-fast-catalog">
            <div class="site-header-catalog__row">
                {% for item in 1..20 %}
                    {% include 'item/catalog-item.twig' %}
                {% endfor %}
            </div>
        </div>
    </div>
</header>