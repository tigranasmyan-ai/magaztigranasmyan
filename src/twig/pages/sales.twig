{% extends 'templates/page.twig' %}

{% block title %}Акции - Aspro{% endblock %}

{% block page_title %}Акции{% endblock %}

{% block page_text %}
    Следите за нашими специальными предложениями и скидками. Мы регулярно обновляем этот раздел, чтобы вы могли приобретать любимые товары по самым выгодным ценам.
{% endblock %}

{% block page_content %}
    <div class="container page__layout page__layout--default">
        {% set tabs = [
            {'id': 'SalesPageActiveList', 'label': 'Активные акции', 'active': true, 'disabled': false},
            {'id': 'SalesPageArchiveList', 'label': 'Архив', 'active': false, 'disabled': false},
        ] %}

        <div id="SalesPageList" role="tablist" class="home-page__tabs tabs-head">
            {% for tab in tabs %}
                <button
                        class="tabs-head__link {% if tab.active %}active{% endif %}"
                        id="{{ tab.id }}-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#{{ tab.id }}-tab-pane"
                        type="button"
                        role="tab"
                        aria-controls="{{ tab.id }}-tab-pane"
                        aria-selected="{{ tab.active ? 'true' : 'false' }}"
                >
                    {{ tab.label }}
                </button>
            {% endfor %}
        </div>

        <div class="tab-content tabs-content" id="HomePageBestProductsContent">
            {% for tab in tabs %}
                <div
                        class="tabs-content__item tab-pane fade {% if tab.active %}show active{% endif %}"
                        id="{{ tab.id }}-tab-pane"
                        role="tabpanel"
                        aria-labelledby="{{ tab.id }}-tab"
                        tabindex="0"
                >
                    <div class="row row-cols-lg-2 row-cols-md-3 row-cols-2 g-md-3 g-2">
                        {% for item in 1..4 %}
                            <div class="col">
                                {% include '../components/sale-card.twig' with {
                                    badge: true
                                } %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{% block page_other_sections %}
    <div class="container section">
        <div class="section__main">
            <h3 class="title title-h3">Вы смотрели</h3>

            <div class="swiper js-products-view-slider">
                <div class="swiper-wrapper">
                    {% for item in 1..10 %}
                        <div class="swiper-slide">
                            <div class="product-view">
                                <a href="">
                                    <img width="96" height="96"
                                         src="https://premier-demo.ru/upload/resize_cache/iblock/a84/192_192_1/goaqzv53n9svrropgfrarjtxeh92fwqa.jpg"
                                         alt="">
                                </a>

                                <a href="" class="product-view__title">
                                    Классическая помада Fior 133 Беспечный розовый
                                </a>

                                <div class="product-view__bottom">
                                    {% include '../shop/price.twig' with {
                                        old: '1 600 ₽/шт',
                                        now: '1 300 ₽/шт',
                                        size: 'sm',
                                        class: 'product-view__price'
                                    } %}

                                    {% include '../components/ui/badge.twig' with {
                                        text: '-10%',
                                        type: 'red',
                                        size: 'sm',
                                        tag: 'div'
                                    } %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="swiper-button-next swiper-arrow"></div>
                <div class="swiper-button-prev swiper-arrow"></div>
            </div>
        </div>
    </div>
{% endblock %}