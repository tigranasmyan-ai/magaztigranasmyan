{% extends 'templates/base.twig' %}

{% set page_settings = {
    classes: {
        body: 'blog-page',
        main: 'blog-page__main',
    },
    title: 'Демоверсия Аспро: Премьер — готовый сайт на 1С-Битрикс',
    breadcrumbs: [
        { text: 'Главная', href: '/' },
        { text: 'Блог', href: '/blog' },
    ],
} %}

{% block content %}
    <section class="section">
        <div class="container section__main">
            <div class="section__head blog-page__head">
                <h1 class="title title-h1">Блог</h1>

                <a class="blog-page__tags-link is-mobile" data-bs-toggle="collapse" href="#BlogPageTags" role="button"
                   aria-expanded="false" aria-controls="BlogPageTags">
                    Теги
                </a>
            </div>

            <div class="blog-page__top">
                <div class="tabs-head is-scrollable-mobile">
                    {% set tabs = [
                        { id: 'popular', label: 'Популярные', active: true },
                        { id: 'new', label: 'Новинки' },
                        { id: 'sale', label: 'Акции' }
                    ] %}

                    {% for tab in tabs %}
                        <a href="" class="tabs-head__link {% if tab.active %}active{% endif %}">
                            {{ tab.label }}
                        </a>
                    {% endfor %}
                </div>

                <a class="blog-page__tags-link is-desktop" data-bs-toggle="collapse" href="#BlogPageTags" role="button"
                   aria-expanded="false" aria-controls="BlogPageTags">
                    Теги
                </a>
            </div>

            <div class="collapse" id="BlogPageTags">
                <div class="blog-page__tags">
                    {% for item in 1..15 %}
                        <div>
                            <a href="" class="button button-sm button-solid">
                                Тег {{ loop.index }}
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="row gx-3 gy-4">
                {% for item in 1..9 %}
                    <div class="col-lg-3 col-md-6">
                        {% include 'item/post/post-item-grid.twig' with {
                            post_solid: true
                        } %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}