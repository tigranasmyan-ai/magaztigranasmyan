<div class="product-item js-product-item {{ disabled_bottom == true ? 'product-item--disabled-bottom' : '' }}" data-view="grid">
    <div class="product-item__top">
        <div class="product-item__badges product-badges">
            {% include '@components/ui/badge.twig' with { badge_text: 'Хит', badge_type: 'green', badge_tag: 'div' } %}
            {% include '@components/ui/badge.twig' with { badge_text: 'Новинка', badge_type: 'orange', badge_tag: 'div' } %}
            {% include '@components/ui/badge.twig' with { badge_text: 'Советуем', badge_type: 'purple', badge_tag: 'div' } %}
        </div>

        {% include '@components/@shop/actions.twig' with {
            actions_list: ['favorite', 'cart', 'wish'],
            actions_classes: 'product-item__actions',
        } %}

        <div class="product-item__gallery gallery">
            <div class="gallery__pictures">
                {% for item in [
                    'https://premier-demo.ru/upload/iblock/3d4/uyjic0vgy8mh1albyq5r2lx819li05tv.jpg',
                    'https://premier-demo.ru/upload/iblock/758/dt2wunwv2okax8uscj0hf1gf7exgbzos.jpg',
                    'https://premier-demo.ru/upload/iblock/cf4/m8koh4m75jq99ykk8l0wg2ohq2xu59f2.jpg',
                ] %}
                    <div class="gallery__picture js-product-item-gallery-picture {{ loop.first ? 'active' : '' }}">
                        <img src="{{ item }}" alt="">
                    </div>
                {% endfor %}
            </div>

            <div class="gallery__dots">
                {% for item in 1..3 %}
                    <div class="gallery__dot js-product-item-gallery-dot"></div>
                {% endfor %}
            </div>
        </div>

        <a data-bs-toggle="modal" data-bs-target="#ProductFastView" class="product-item__fast-view fast-view-button">Быстрый просмотр</a>
    </div>

    <div class="product-item__content">
        <div class="gallery__pagination">
            <span class="active js-product-item-gallery-bullet"></span>
            <span class="js-product-item-gallery-bullet"></span>
            <span class="js-product-item-gallery-bullet"></span>
            <span class="js-product-item-gallery-bullet"></span>
        </div>

        {% include '@components/@shop/price.twig' with {
            price_size: 'md',
            price_class: 'product-item__price'
        } %}

        {% include '@components/@shop/cashback.twig' with {
            class: 'product-item__cashback'
        } %}

        <a href="product-single.html" class="product-item__title title title-h7">
            Классическая помада Fior 133 Беспечный розовый
        </a>

        <div class="product-item__info info-box">
            <div class="info-box__item">
                <div class="info-box__icon">
                    <svg width="14" height="15">
                        <use xlink:href="img/svg/icons.svg#star"></use>
                    </svg>
                </div>

                <span class="info-box__text">9</span>
            </div>

            <div class="info-box__item">
                <div class="info-box__icon is-comment">
                    <svg width="13" height="12">
                        <use xlink:href="img/svg/icons.svg#review"></use>
                    </svg>
                </div>

                <span class="info-box__text">0</span>
            </div>

            <div class="info-box__item">
                <div class="status">
                    <svg width="13" height="12">
                        <use xlink:href="img/svg/icons.svg#instock"></use>
                    </svg>

                    <span class="status__text">В наличии</span>
                </div>
            </div>
        </div>

        <a href="" class="product-item__button button button-sm button-default">В корзину</a>
    </div>

    {% if disabled_bottom != true %}
        <div class="product-item__bottom">
            <div class="product-item__variants variants">
                {% for item in 1..2 %}
                    <div class="variant">
                        <div class="variant__title">Цвет: 232 Нежный кашемир</div>

                        <div class="variant__list">
                            {% for item in 1..12 %}
                                <button type="button" class="variant__item {{ loop.index == 1 ? 'active' : '' }}">
                                    <img src="https://premier-demo.ru/upload/iblock/ca7/cyah1pp4hju0qyqahn0u32rv5hplyn17.jpg"
                                         alt="">
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="product-item__props properties">
                <div class="properties__item">
                    <span>Материал:</span>
                    <span><a href="">Дерево</a>, <a href="">Пластик</a></span>
                </div>

                <div class="properties__item">
                    <span>Общая мощность, Вт:</span>
                    <span>12</span>
                </div>

                <div class="properties__item">
                    <span>Габариты (ВхШхГ), см:</span>
                    <span>13х34х6</span>
                </div>

                <div class="properties__item">
                    <span>Дополнительно:</span>
                    <span>Кодирование звука в MP3 формат</span>
                </div>
            </div>
        </div>
    {% endif %}
</div>