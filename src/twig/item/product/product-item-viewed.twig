<div class="product-item-viewed {{ class }}">
    <a href="{{ href|default('') }}">
        <img width="96" height="96"
             src="{{ image|default('https://premier-demo.ru/upload/resize_cache/iblock/a84/192_192_1/goaqzv53n9svrropgfrarjtxeh92fwqa.jpg') }}"
             alt="{{ title|default('') }}">
    </a>

    <a href="{{ href|default('') }}" class="product-item-viewed__title">
        {{ title|default('Классическая помада Fior 133 Беспечный розовый') }}
    </a>

    <div class="product-item-viewed__bottom">
        {% include '@components/@shop/price.twig' with {
            price_size: 'sm',
            price_class: 'product-item-viewed__price'
        } %}

        {% include '@components/ui/badge.twig' with {
            badge_text: badge.text|default('-10%'),
            badge_type: badge.type|default('red'),
            badge_size: badge.size|default('sm'),
            badge_tag: 'div'
        } %}
    </div>
</div>
