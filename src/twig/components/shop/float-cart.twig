<div class="site-header-action__dropdown float-cart {{ class }}">
    <div class="float-cart__scroll">
        {% for item in 1..10 %}
            <div class="float-cart-product">
                <button type="button" class="float-cart-product__remove">
                    <svg width="18" height="18">
                        <use xlink:href="img/svg-icons.svg#remove"></use>
                    </svg>
                </button>

                <a href="">
                    <picture class="float-cart-product__picture">
                        <img src="https://premier-demo.ru/upload/resize_cache/iblock/c28/64_64_1/uw5p61iophgtnli7sok77hrmswpg2924.jpg"
                             alt="" class="float-cart-product__img">
                    </picture>
                </a>

                <div class="float-cart-product__info">
                    {% if cart %}
                        <div class="float-cart-product__price float-cart-product-price">
                            <div class="float-cart-product-price__now">
                                600 ₽
                            </div>
                            <div class="float-cart-product-price__old">
                                300 ₽
                            </div>
                        </div>

                        {% include './cashback.twig' %}
                    {% endif %}

                    <a href="" class="float-cart-product__name">
                        Набор для создания свечи
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="float-cart__total float-cart-total">
        {% if cart %}
            <div class="float-cart-total__top">
                <span class="float-cart-total__title">
                    Итого
                </span>

                <div class="float-cart-total__info">
                    <div class="float-cart-total__price float-cart-total-price">
                        <span class="float-cart-total-price__now">
                            87 359 ₽
                        </span>

                        <span class="float-cart-total-price__old">
                            87 359 ₽
                        </span>
                    </div>

                    {% include './cashback.twig' %}
                </div>
            </div>
        {% endif %}

        <a href="" class="button button-default button-lg float-cart-total__button">
            Перейти в корзину
        </a>
    </div>
</div>